{
  "expo": {
    "name": "DoorDrill",
    "slug": "doordrill-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.doordrill.mobile"
    },
    "android": {
      "package": "com.doordrill.mobile"
    },
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:8000",
      "wsBaseUrl": "ws://127.0.0.1:8000"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
