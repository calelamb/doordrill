# ==========================================
# DoorDrill Backend Environment Configuration
# ==========================================

# -----------------
# Core
# -----------------
ENVIRONMENT=dev
LOG_LEVEL=INFO
# SQLite is used by default for local development
# DATABASE_URL=sqlite:///./doordrill.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/doordrill

# -----------------
# AI Providers (The big ones!)
# -----------------
# Change these from "mock" to the actual provider name to enable live AI interactions
STT_PROVIDER=mock    # Options: mock, deepgram
LLM_PROVIDER=mock    # Options: mock, openai, anthropic
TTS_PROVIDER=mock    # Options: mock, elevenlabs

# -----------------
# API Keys
# -----------------
# Deepgram (for Speech-to-Text)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# DEEPGRAM_MODEL=nova-2

# OpenAI (for LLM and Whisper cleanup)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (Alternative for LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ElevenLabs (for Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optionally specify a default voice ID
# ELEVENLABS_VOICE_ID=your_voice_id_here
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# -----------------
# Object Storage (S3 / Cloudflare R2 / AWS)
# Used for storing audio artifacts and transcripts
# -----------------
# OBJECT_STORAGE_ENDPOINT=https://s3.us-east-1.amazonaws.com
# OBJECT_STORAGE_REGION=us-east-1
# OBJECT_STORAGE_ACCESS_KEY=your_access_key
# OBJECT_STORAGE_SECRET_KEY=your_secret_key
# STORAGE_BUCKET=doordrill-session-artifacts

# -----------------
# Authentication (JWT)
# -----------------
# Auth is REQUIRED by default. Set to False only for local development.
# AUTH_REQUIRED=True
# AUTH_MODE=jwt

# REQUIRED for production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=
# JWT_ALGORITHM=HS256

# CORS: comma-separated list of allowed origins for production
# CORS_ALLOWED_ORIGINS=["https://app.doordrill.com"]

# Max file upload size in bytes (default 5MB)
# MAX_UPLOAD_SIZE_BYTES=5242880

# -----------------
# Notifications & Queueing (Optional)
# -----------------
# USE_CELERY=False
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# SENDGRID_API_KEY=your_sendgrid_key_here
# SENDGRID_FROM_EMAIL=noreply@doordrill.com
