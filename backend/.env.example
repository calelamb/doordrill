ENVIRONMENT=dev
DATABASE_URL=sqlite:///./doordrill.db
REDIS_URL=redis://localhost:6379/0

AUTH_REQUIRED=false
AUTH_MODE=headers
JWT_SECRET=dev-jwt-secret-change-me
JWT_JWKS_URL=

USE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

STT_PROVIDER=mock
LLM_PROVIDER=mock
TTS_PROVIDER=mock
PROVIDER_TIMEOUT_SECONDS=10

DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MANAGER_AI_MODEL=
MANAGER_AI_FAST_MODEL=
MANAGER_AI_FALLBACK_PROVIDER=
MANAGER_AI_FALLBACK_MODEL=
MANAGER_AI_FALLBACK_FAST_MODEL=
MANAGER_AI_ALLOW_MOCK=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

STORAGE_BUCKET=doordrill-session-artifacts
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_PUBLIC_BASE_URL=

WHISPER_CLEANUP_ENABLED=false
MANAGER_NOTIFICATION_EMAIL_ENABLED=false
MANAGER_NOTIFICATION_PUSH_ENABLED=false
NOTIFICATION_PUSH_PROVIDER=expo
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
EXPO_PUSH_ACCESS_TOKEN=
FCM_SERVER_KEY=
NOTIFICATION_MAX_RETRIES=5
NOTIFICATION_RETRY_BASE_SECONDS=30
MANAGEMENT_ANALYTICS_CACHE_TTL_SECONDS=60
MANAGEMENT_ANALYTICS_CACHE_MAX_ENTRIES=512
MANAGEMENT_ANALYTICS_WARN_MS=800
MANAGEMENT_ANALYTICS_CRITICAL_MS=1500

# Error monitoring (get DSN from sentry.io -> Project Settings -> Client Keys)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
